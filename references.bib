% references.bib — Quarto picks up entries here for [@key] citations.
%
% Cite anywhere in a .qmd:
%     Following @raissi2019pinn, the residual loss is ...
%     [@raissi2019pinn; @ethier1994exact]
%
% Quarto renders a "References" section at the end of each page that uses citations.
% Default style: Chicago author-date. Override with `csl: <path-or-url>` in the
% page YAML or in _quarto.yml — see https://www.zotero.org/styles for IEEE, AMS, JFM, etc.
%
% Example entries (uncomment to use):
%
% @article{raissi2019pinn,
%   author    = {Raissi, M. and Perdikaris, P. and Karniadakis, G. E.},
%   title     = {Physics-informed neural networks: A deep learning framework
%                for solving forward and inverse problems involving nonlinear
%                partial differential equations},
%   journal   = {Journal of Computational Physics},
%   volume    = {378},
%   pages     = {686--707},
%   year      = {2019},
%   doi       = {10.1016/j.jcp.2018.10.045}
% }
%
% @article{ethier1994exact,
%   author    = {Ethier, C. R. and Steinman, D. A.},
%   title     = {Exact fully {3D} {Navier-Stokes} solutions for benchmarking},
%   journal   = {International Journal for Numerical Methods in Fluids},
%   volume    = {19},
%   pages     = {369--375},
%   year      = {1994}
% }
